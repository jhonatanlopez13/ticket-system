# Puerto del servidor
PORT=4000

# Origen permitido para CORS (URL del frontend)
CORS_ORIGIN=http://localhost:5173

# Credenciales del Service Account de Firebase
# (Firebase Console > Configuración del proyecto > Cuentas de servicio > Generar nueva clave privada)
#
# OPCIÓN RECOMENDADA (sobre todo en Windows): no uses estas variables.
# En su lugar, guarda el archivo .json descargado como "backend/serviceAccountKey.json"
# y el backend lo detectará automáticamente. No necesitas tocar nada más.
#
# OPCIÓN ALTERNATIVA: si prefieres usar variables de entorno, pega aquí el JSON completo
# del service account EN UNA SOLA LÍNEA, entre comillas simples:
# FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n", ...}'

# O, si guardaste el archivo json en otra ruta/nombre, indícala aquí:
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Email del primer super administrador que se creará automáticamente al iniciar el servidor si no existe
BOOTSTRAP_SUPERADMIN_EMAIL=superadmin@tuempresa.com
BOOTSTRAP_SUPERADMIN_PASSWORD=CambiaEstaClave123!
BOOTSTRAP_SUPERADMIN_NAME=Super Administrador
